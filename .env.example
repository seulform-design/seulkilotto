# ──────────────────────────────────────────────────────────────
# Lotto Analyzer — 환경 변수 템플릿
# 실제 값은 .env (gitignored) 에 채워 넣을 것.
# ──────────────────────────────────────────────────────────────

# ── 공통 ──────────────────────────────────────────────────────
# CORS: 정적 허용 origin (쉼표 구분). Quick Tunnel/Render/localhost 는
# main.py 의 정규식에서 자동 허용되므로 여기 추가할 필요 없음.
# 추가 도메인이 있을 때만 채울 것. 예: https://my-staging.example.com
CORS_ORIGINS=
# 정규식으로 추가 origin 을 허용할 때만 사용. 예: https://[a-z]+\.example\.com
CORS_ORIGIN_REGEX_EXTRA=

# ── v1 API (backend/) ────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/lotto
CURRENT_ROUND=1227
HISTORY_CACHE_TTL=300
CRAWL_SOURCE=lottis
SCHEDULER_ENABLED=true
UPGRADE_API_KEY=

# 유튜브 영상 패턴 분석 (OpenAI Vision, 선택)
VIDEO_VISION_API_KEY=
VIDEO_VISION_MODEL=gpt-4o-mini
VIDEO_ANALYSIS_MAX_FRAMES=36

# ── v2 API (platform/backend/) ───────────────────────────────
ADMIN_API_KEY=change-me-in-production
# v2 의 SCHEDULER 는 별도 키로 분리하는 것을 권장. 현재는 v1 과 동일 키 공유 상태.
# SCHEDULER_ENABLED 가 두 백엔드를 동시에 제어한다는 점 인지할 것.
